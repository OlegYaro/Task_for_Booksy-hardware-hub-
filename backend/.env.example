# Copy to .env and fill in.

# development (default) allows the placeholder secrets below for a quick local
# run. Set ENVIRONMENT=production and the app refuses to boot until SECRET_KEY
# and DEFAULT_ADMIN_PASSWORD are changed from their defaults (fail-closed).
ENVIRONMENT=development

# Secret used to sign JWT access tokens. MUST be changed in production —
# the default is public, so a shared default = anyone can forge admin tokens.
SECRET_KEY=dev-secret-change-me

# Anthropic API key for the AI layer (Inventory Auditor + Semantic Search).
# Leave empty to run the AI layer in deterministic fallback mode (no network calls).
ANTHROPIC_API_KEY=

# Model used for the AI features.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
